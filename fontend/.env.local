# Local overrides — takes priority over .env.development / .env.production
# Fill in your real values here

# Backend API base URL
VITE_API_BASE_URL=your_backend_api_url_here
VITE_APP_ID=vibe-tools

# Markdown Parser API (external server)
VITE_MARKDOWN_API_URL=your_markdown_api_url_here
VITE_MARKDOWN_API_KEY=your_markdown_api_key_here
