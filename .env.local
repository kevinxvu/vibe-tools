# Server settings
STAGE=development
PORT=8080
READ_TIMEOUT=10
WRITE_TIMEOUT=5
ALLOW_ORIGINS=*
DEBUG=true
IS_ENABLE_API_DOCS=true
API_DOCS_PATH=docs
APP_ID=vibetools

# JWT settings
JWT_SECRET=jwtsecret
JWT_DURATION=31536001 # 1 year in seconds
JWT_ALGORITHM=HS256

# LLM settings
LLM_TEXT_MODEL=gemini-3-flash-preview
LLM_AUDIO_MODEL=gemini-3-flash-preview
LLM_PROVIDER=openai
LLM_MAX_INPUT_TOKENS=12000
LLM_LIMIT_TOKEN_USAGE=10000000

# OpenAI settings
OPENAI_API_KEY="key"
OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# GenAI settings
GENAI_API_KEY="key"
